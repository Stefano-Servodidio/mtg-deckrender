# Environment Variables
# Copy this file to .env.local and fill in your actual values

# Google Analytics 4 Measurement ID
# Get your GA4 ID from: https://analytics.google.com/analytics/web/
# Format: G-XXXXXXXXXX
# For development, you can use a dummy ID like: G-XXXXXXXXXX
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Scryfall API Configuration
API_URL_SCRYFALL=https://api.scryfall.com
API_USER_AGENT=mtg-deck-to-png/1.0-dev (servodidio.stefano@gmail.com)

# Maintenance Mode
# Set to true to enable maintenance mode
NEXT_PUBLIC_MAINTENANCE=false

# Netlify Blobs Configuration (Optional - for local development only)
# Only needed if you want to test Netlify Blobs integration locally
# On Netlify, these are automatically injected - DO NOT set in .env.production
# Get these from: https://app.netlify.com/sites/[your-site]/configuration/env
# NETLIFY_SITE_ID=your-site-id-here
# NETLIFY_AUTH_TOKEN=your-auth-token-here

# Blog Admin Token (for managing blog posts via API)
BLOG_ADMIN_TOKEN=your-secure-random-token-here

# Overlay Size
OVERLAY_SIZE=110