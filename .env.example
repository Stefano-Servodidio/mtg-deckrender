# Environment Variables
# Copy this file to .env.local and fill in your actual values

# Google Analytics 4 Measurement ID
# Get your GA4 ID from: https://analytics.google.com/analytics/web/
# Format: G-XXXXXXXXXX
# For development, you can use a dummy ID like: G-XXXXXXXXXX
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Scryfall API Configuration
API_URL_SCRYFALL=https://api.scryfall.com
API_USER_AGENT=mtg-deck-to-png/1.0-dev (servodidio.stefano@gmail.com)

# Maintenance Mode
# Set to true to enable maintenance mode
NEXT_PUBLIC_MAINTENANCE=false

# Netlify Configuration
NETLIFY_SITE_ID=11111111111111111111111111111111
NETLIFY_AUTH_TOKEN=11111111111111111111111111111111

# Overlay Size
OVERLAY_SIZE=110