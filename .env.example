# Environment Variables
# Copy this file to .env.local and fill in your actual values

# Google Analytics 4 Measurement ID
# Get your GA4 ID from: https://analytics.google.com/analytics/web/
# Format: G-XXXXXXXXXX
# For development, you can use a dummy ID like: G-XXXXXXXXXX
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Scryfall API Configuration (if needed)
# NEXT_PUBLIC_API_URL_SCRYFALL=https://api.scryfall.com
# NEXT_PUBLIC_API_USER_AGENT=MTGDeckToPNG/1.0
