{
    "name": "nextjs",
    "version": "0.7.1",
    "private": true,
    "engines": {
        "node": ">=22.12.0"
    },
    "scripts": {
        "dev": "next dev",
        "build": "next build",
        "start": "next start",
        "lint": "next lint",
        "format": "prettier --write .",
        "type:check": "tsc --noEmit",
        "test": "vitest",
        "test:run": "vitest run",
        "test:ui": "vitest --ui",
        "test:coverage": "vitest run --coverage",
        "cypress:open": "cypress open",
        "cypress:run": "cypress run",
        "cypress:component": "cypress run --component",
        "e2e": "start-server-and-test dev http://localhost:3000 cypress:run",
        "e2e:open": "start-server-and-test dev http://localhost:3000 cypress:open",
        "validate:e2e": "node scripts/validate-cypress.js",
        "test:e2e-flow": "node scripts/test-e2e-flow.js",
        "generate:overlays": "node --env-file=.env.local scripts/generate-overlays.js",
        "bump:patch": "npm version patch && git push && git push --tags",
        "bump:minor": "npm version minor && git push && git push --tags",
        "bump:major": "npm version major && git push && git push --tags"
    },
    "lint-staged": {
        "*.{ts,tsx, js, jsx, css}": [
            "eslint --fix",
            "prettier --write"
        ]
    },
    "dependencies": {
        "@chakra-ui/react": "^2.10.9",
        "@emotion/react": "^11.11.4",
        "@emotion/styled": "^11.11.0",
        "@hookform/resolvers": "^3.9.0",
        "@netlify/blobs": "^10.1.0",
        "@next/swc-wasm-nodejs": "13.5.1",
        "@types/node": "^22.12.0",
        "@types/react": "^18.3.24",
        "@types/react-dom": "^18.3.7",
        "autoprefixer": "10.4.15",
        "chalk": "^5.6.2",
        "class-variance-authority": "^0.7.0",
        "clsx": "^2.1.1",
        "cmdk": "^1.0.0",
        "date-fns": "^3.6.0",
        "embla-carousel-react": "^8.3.0",
        "eslint": "^9.0.0",
        "eslint-config-next": "^15.5.3",
        "framer-motion": "^6.5.1",
        "input-otp": "^1.2.4",
        "lucide-react": "^0.446.0",
        "next": "^14.2.32",
        "next-themes": "^0.3.0",
        "react": "^18.3.1",
        "react-day-picker": "^8.10.1",
        "react-dom": "^18.3.1",
        "react-dropzone": "^14.3.8",
        "react-icons": "^5.5.0",
        "react-resizable-panels": "^2.1.3",
        "recharts": "^2.12.7",
        "sharp": "^0.34.3",
        "typescript": "^5.9.2",
        "vaul": "^0.9.9",
        "zod": "^3.23.8"
    },
    "devDependencies": {
        "@cypress/react": "^9.0.1",
        "@eslint/eslintrc": "^3.3.1",
        "@eslint/js": "^9.35.0",
        "@netlify/plugin-nextjs": "^5.13.3",
        "@testing-library/dom": "^10.4.1",
        "@testing-library/jest-dom": "^6.8.0",
        "@testing-library/react": "^16.3.0",
        "@vitejs/plugin-react": "^5.0.2",
        "@vitest/coverage-v8": "^3.2.4",
        "@vitest/ui": "^3.2.4",
        "cypress": "^15.3.0",
        "cypress-file-upload": "^5.0.8",
        "eslint-plugin-unused-imports": "^4.2.0",
        "jsdom": "^27.0.0",
        "lint-staged": "^16.1.6",
        "prettier": "3.6.2",
        "start-server-and-test": "^2.1.2",
        "vite": "^7.1.5",
        "vitest": "^3.2.4"
    }
}
